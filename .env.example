# 두루누비 API (data.go.kr)
DURUNUBI_API_KEY=your-decoded-key
DURUNUBI_API_KEY_ENC=your-encoded-key

# Gemini API
GEMINI_API_KEY=your-gemini-key

# Vercel Cron
CRON_SECRET=random-32-byte-hex
